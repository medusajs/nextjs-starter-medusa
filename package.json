{
  "name": "idstudio-rh-workspace",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --filter=\"./packages/*\" dev",
    "dev:rh": "pnpm --filter \"./packages/rh-storefront\" dev",
    "dev:ids": "pnpm --filter id-studio dev",
    "dev:cms": "pnpm --filter strapi-cms develop",
    "build": "pnpm -r --filter=\"./packages/*\" build",
    "lint": "pnpm -r --filter=\"./packages/*\" lint",
    "typecheck": "pnpm -r --filter=\"./packages/*\" exec tsc --noEmit",
    "typegen:cms": "pnpm --filter strapi-cms exec strapi ts:generate-types",
    "seed": "pnpm --filter @workspace/seed start",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
